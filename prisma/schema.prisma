// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
   moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  password     String
  currency     String   @default("PLN")
  distanceUnit String   @default("km")
  theme        String   @default("system")
  language     String   @default("en")
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  picture      String?

  ownedFamilies Family?
  familyMember FamilyMember[]
  ownedCars       Car[] @relation("CarOwner")
  fuelCards       FuelCard[]
  reminders       Reminder[]
  createdServices     ServiceRecord[]
  createdFuelRecords  FuelRecord[]
  createdExpenses     Expense[]
  createdTransactions FuelCardTransaction[]
  uploadedDocuments   Document[] 
  notifications Notification[]
}

model Car {
  id          String   @id @default(uuid())
  ownerId     String
  plate       String?
  brand       String?
  model       String?
  year        Int?
  fuelType    FuelType  @default(PETROL)
  currentKm   Int @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  familyId    String?

  owner       User @relation("CarOwner", fields: [ownerId], references: [id])

  family      Family? @relation(fields: [familyId], references: [id])
  services    ServiceRecord[]
  fuels       FuelRecord[]
  expenses    Expense[]
  documents   Document[]
  reminders   Reminder[]
  cardTransactions FuelCardTransaction[]
  photos  CarPhotos[]
  notifications Notification[]
}

model Family {
  id        String   @id @default(uuid())
  name      String
  ownerId   String @unique 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User @relation(fields: [ownerId], references: [id])

  members   FamilyMember[]
  cars      Car[]
  notifications Notification[]
}

model FamilyMember {
  id           String   @id @default(uuid())
  familyId     String
  userId       String
  role         FamilyRole @default(MEMBER)
  createdAt    DateTime @default(now())
  is_approved  Boolean   @default(false)

  family       Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model CarPhotos {
  id              String   @id @default(uuid())
  carId           String
  url             String?
  is_cover        Boolean  @default(false)
  fileName        String
  mimeType        String?
  createdAt       DateTime @default(now())

  car   Car @relation(fields: [carId], references: [id], onDelete: Cascade)
}


enum CarRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum FuelType {
  PETROL
  DIESEL
  LPG
  ELECTRIC
}

model ServiceRecord {
  id          String   @id @default(uuid())
  carId       String
  createdById String?
  category    ServiceCategory @default(OTHER)
  title       String?
  description String?
  amount      Decimal?  @db.Decimal(10, 2) 
  km          Int
  currency         String
  convertedAmount  Float?
  convertedCurrency String?
  serviceDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  car         Car   @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdBy   User? @relation(fields: [createdById], references: [id])

  attachments ServiceAttachment[]
}

enum ServiceCategory {
  OIL_CHANGE
  FILTER_CHANGE
  BRAKE
  TIRE
  BATTERY
  ENGINE
  TRANSMISSION
  SUSPENSION
  AC
  INSPECTION
  WASH
  OTHER
}

model ServiceAttachment {
  id              String   @id @default(uuid())
  serviceRecordId String
  url             String
  fileName        String
  mimeType        String?
  createdAt       DateTime @default(now())

  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
}

model FuelRecord {
  id          String   @id @default(uuid())
  carId       String
  createdById String?

  fuelCardTransactionId String? @unique

  station     String?
  liters      Decimal? @db.Decimal(10, 2)
  pricePerLiter Decimal @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  km          Int     @default(0)
  consumption Decimal? @db.Decimal(10, 2) @default(0)
  fuelDate    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  currency         String
  convertedAmount  Float?
  convertedCurrency String?

  car             Car @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdBy       User? @relation(fields: [createdById], references: [id])
  cardTransaction FuelCardTransaction? @relation(fields: [fuelCardTransactionId], references: [id])

  attachments FuelAttachment[]
}

model FuelAttachment {
  id              String   @id @default(uuid())
  fuelRecordId    String
  url             String?
  fileName        String
  mimeType        String?
  createdAt       DateTime @default(now())

  fuelRecord   FuelRecord @relation(fields: [fuelRecordId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(uuid())
  carId       String
  createdById String?
  category    ExpenseCategory
  title       String
  mileage     Int      @default(0)
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  expenseDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  currency         String
  convertedAmount  Float?
  convertedCurrency String?

  car         Car   @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdBy   User? @relation(fields: [createdById], references: [id])
  attachments ExpenseAttachment[]
}

enum ExpenseCategory {
  FUEL
  SERVICE
  INSURANCE
  TAX
  PARKING
  CAR_WASH
  TOLL
  TIRE
  DOCUMENT
  OTHER
}

model ExpenseAttachment {
  id              String   @id @default(uuid())
  expenseId    String
  url             String?
  fileName        String
  mimeType        String?
  createdAt       DateTime @default(now())

  expense         Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model FuelCard {
  id          String   @id @default(uuid())
  userId      String
  name        String
  provider    String?
  lastFour    String?
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("PLN")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions FuelCardTransaction[]
}

model FuelCardTransaction {
  id          String   @id @default(uuid())
  fuelCardId  String
  carId       String?
  createdById String?
  type        FuelCardTransactionType
  amount      Decimal  @db.Decimal(10, 2)
  note        String?
  station     String?
  transactionDate DateTime
  createdAt   DateTime @default(now())

  fuelCard    FuelCard @relation(fields: [fuelCardId], references: [id], onDelete: Cascade)
  car         Car? @relation(fields: [carId], references: [id])
  createdBy   User? @relation(fields: [createdById], references: [id])
  fuelRecord  FuelRecord?
}

enum FuelCardTransactionType {
  TOP_UP
  SPEND
}

model Document {
  id          String   @id @default(uuid())
  carId       String
  uploadedById String?
  type        DocumentType
  title       String?
  fileUrl     String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  car         Car @relation(fields: [carId], references: [id], onDelete: Cascade)
  uploadedBy  User? @relation(fields: [uploadedById], references: [id])
  attachments DocumentAttachment[]
}

enum DocumentType {
  REGISTRATION
  INSURANCE
  INSPECTION
  INVOICE
  SERVICE_REPORT
  PURCHASE_INVOICE
  ROADSIDE_ASSISTANCE
  OTHER
}


model DocumentAttachment {
  id              String   @id @default(uuid())
  documentId      String
  url             String?
  fileName        String
  mimeType        String?
  createdAt       DateTime @default(now())

  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String
  carId       String?
  title       String
  type        ReminderType
  dueDate     DateTime?
  dueKm       Int?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car         Car? @relation(fields: [carId], references: [id], onDelete: Cascade)
}

enum ReminderType {
  INSURANCE
  INSPECTION
  SERVICE
  OIL_CHANGE
  TIRE_ROTATION
  TAX
  CUSTOM
  YES
}

model Notification {
  id          String             @id @default(uuid())
  userId      String
  title       String
  message     String
  type        NotificationType
  isRead      Boolean            @default(false)

  familyId    String?
  carId       String?

  createdAt   DateTime           @default(now())
  readAt      DateTime?

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  family       Family?           @relation(fields: [familyId], references: [id])
  car          Car?              @relation(fields: [carId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  FAMILY_INVITE
  FAMILY_MEMBER_JOINED
  FAMILY_MEMBER_REMOVED

  REMINDER_DUE
  REMINDER_OVERDUE

  DOCUMENT_EXPIRING
  INSURANCE_EXPIRING
  INSPECTION_EXPIRING

  SERVICE_DUE
  OIL_CHANGE_DUE

  CAR_SHARED

  INFO
}