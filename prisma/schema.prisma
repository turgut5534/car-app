// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
   moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  password     String
  currency     String   @default("PLN")
  distanceUnit String   @default("km")
  theme        String   @default("system")
  language     String   @default("en")
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedCars       Car[] @relation("CarOwner")
  carMemberships  CarMember[]
  fuelCards       FuelCard[]
  reminders       Reminder[]

  createdServices     ServiceRecord[]
  createdFuelRecords  FuelRecord[]
  createdExpenses     Expense[]
  createdTransactions FuelCardTransaction[]

  uploadedDocuments   Document[] 
}

model Car {
  id          String   @id @default(uuid())
  ownerId     String
  plate       String?
  brand       String?
  model       String?
  year        Int?
  fuelType    String?
  currentKm   Int?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User @relation("CarOwner", fields: [ownerId], references: [id])
  members     CarMember[]

  services    ServiceRecord[]
  fuels       FuelRecord[]
  expenses    Expense[]
  documents   Document[]
  reminders   Reminder[]
  cardTransactions FuelCardTransaction[]
}

model CarMember {
  id        String   @id @default(uuid())
  carId     String
  userId    String
  role      CarRole  @default(MEMBER)
  createdAt DateTime @default(now())

  car       Car  @relation(fields: [carId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([carId, userId])
}

enum CarRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model ServiceRecord {
  id          String   @id @default(uuid())
  carId       String
  createdById String?
  category    ServiceCategory @default(OTHER)
  title       String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  km          Int?
  serviceDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  car         Car   @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdBy   User? @relation(fields: [createdById], references: [id])
}

enum ServiceCategory {
  OIL_CHANGE
  FILTER_CHANGE
  BRAKE
  TIRE
  BATTERY
  ENGINE
  TRANSMISSION
  SUSPENSION
  AC
  INSPECTION
  WASH
  OTHER
}

model FuelRecord {
  id          String   @id @default(uuid())
  carId       String
  createdById String?

  fuelCardTransactionId String? @unique

  station     String?
  liters      Decimal? @db.Decimal(10, 2)
  pricePerLiter Decimal? @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  km          Int?
  fuelDate    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  car             Car @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdBy       User? @relation(fields: [createdById], references: [id])
  cardTransaction FuelCardTransaction? @relation(fields: [fuelCardTransactionId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  carId       String
  createdById String?
  category    ExpenseCategory
  title       String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  expenseDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  car         Car   @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdBy   User? @relation(fields: [createdById], references: [id])
}

enum ExpenseCategory {
  FUEL
  SERVICE
  INSURANCE
  TAX
  PARKING
  CAR_WASH
  TOLL
  TIRE
  DOCUMENT
  OTHER
}

model FuelCard {
  id          String   @id @default(uuid())
  userId      String
  name        String
  provider    String?
  lastFour    String?
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("PLN")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions FuelCardTransaction[]
}

model FuelCardTransaction {
  id          String   @id @default(uuid())
  fuelCardId  String
  carId       String?
  createdById String?
  type        FuelCardTransactionType
  amount      Decimal  @db.Decimal(10, 2)
  note        String?
  station     String?
  transactionDate DateTime
  createdAt   DateTime @default(now())

  fuelCard    FuelCard @relation(fields: [fuelCardId], references: [id], onDelete: Cascade)
  car         Car? @relation(fields: [carId], references: [id])
  createdBy   User? @relation(fields: [createdById], references: [id])
  fuelRecord  FuelRecord?
}

enum FuelCardTransactionType {
  TOP_UP
  SPEND
}

model Document {
  id          String   @id @default(uuid())
  carId       String
  uploadedById String?
  type        DocumentType
  title       String
  fileUrl     String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  car         Car @relation(fields: [carId], references: [id], onDelete: Cascade)
  uploadedBy  User? @relation(fields: [uploadedById], references: [id])
}

enum DocumentType {
  REGISTRATION
  INSURANCE
  INSPECTION
  INVOICE
  SERVICE_REPORT
  PURCHASE_INVOICE
  ROADSIDE_ASSISTANCE
  OTHER
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String
  carId       String?
  title       String
  type        ReminderType
  dueDate     DateTime?
  dueKm       Int?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car         Car? @relation(fields: [carId], references: [id], onDelete: Cascade)
}

enum ReminderType {
  INSURANCE
  INSPECTION
  SERVICE
  OIL_CHANGE
  TIRE_ROTATION
  TAX
  CUSTOM
  YES
}